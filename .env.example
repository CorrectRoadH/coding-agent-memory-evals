# 复制成 .env 并填值(.env 已被 gitignore)。
# 所有 agent 共用一个 OpenAI 兼容代理;模型由实验 ctx.model 给(compare/ 里钉的是 gpt-5.4)。

# codex:写进 ~/.codex/config.toml 的自定义 model_provider(wire_api=responses → 打到 {base}/responses)
CODEX_API_KEY=sk-...
CODEX_BASE_URL=https://your-proxy.example/v1

# bub:同一个代理
BUB_API_KEY=sk-...
BUB_API_BASE=https://your-proxy.example/v1

# 云沙箱后端凭据(可选;不填则用本地 docker)。
# vercel:sandbox: "vercel"
VERCEL_API_TOKEN=vcp_...
VERCEL_TEAM_ID=team_...
VERCEL_PROJECT_ID=vercel-sandbox-default-project
# e2b:sandbox: "e2b" / e2bSandbox(...)
E2B_API_KEY=e2b_...
