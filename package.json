{
  "name": "coding-agent-memory-evals",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "用 niceeval 写的「coding agent 记忆能力」评测套件,跨 claude-code / codex / bub",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "list": "niceeval list",
    "smoke": "niceeval exp dev memory/agent-029-use-cache-directive",
    "dev": "niceeval exp dev",
    "compare": "niceeval exp compare",
    "codex": "niceeval --agent codex",
    "view": "niceeval view",
    "snapshot": "node scripts/snapshot-results.mjs",
    "report": "node scripts/build-site.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "niceeval": "link:../fastevals",
    "typescript": "^6.0.3"
  }
}
